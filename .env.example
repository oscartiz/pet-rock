# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bluesky (AT Protocol)
BLUESKY_IDENTIFIER=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Ethereum
# Leave ETH_PRIVATE_KEY blank on first run — the agent will generate a wallet,
# write it to ./wallet.key (mode 600), print it, and exit. Move the key into
# this file (or load it from wallet.key) and restart.
ETH_PRIVATE_KEY=
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Tuning
POST_INTERVAL_MINUTES=30
HUNGER_DECAY_PER_HOUR=3
MODEL=claude-haiku-4-5

# Storage — override on hosts with persistent volumes (e.g. /data/petrock.db on Fly).
# DB_PATH=./petrock.db
