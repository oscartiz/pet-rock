# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bluesky (AT Protocol)
BLUESKY_IDENTIFIER=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Ethereum
# Leave ETH_PRIVATE_KEY blank on first run — the agent will generate a wallet and print the key.
# Copy the printed key here and restart.
ETH_PRIVATE_KEY=
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Tuning
POST_INTERVAL_MINUTES=30
HUNGER_DECAY_PER_HOUR=3
